{
	"name": "@orgsdk/plugins",
	"version": "0.2.0",
	"description": "Authoring contract, types, validation, and CLI for OrgSDK plugin developers.",
	"type": "module",
	"license": "Apache-2.0",
	"main": "src/index.ts",
	"types": "src/index.ts",
	"bin": {
		"orgsdk-plugin": "./src/cli.ts"
	},
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./schema/plugin-manifest.v1.json": "./schemas/plugin-manifest.v1.json"
	},
	"files": [
		"src",
		"schemas",
		"README.md",
		"CHANGELOG.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"check": "biome check .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"generate-schema": "bun scripts/generate-schema.ts",
		"schema:check": "bun test tests/schema-drift.test.ts",
		"workflows:check": "bun test tests/workflows.test.ts",
		"pack:dry-run": "bun pm pack --dry-run"
	},
	"peerDependencies": {
		"zod": "^3.23.0 || ^4.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@types/bun": "^1.3.9",
		"typescript": "~6.0.3",
		"zod": "^4.0.0"
	},
	"keywords": [
		"orgsdk",
		"plugin",
		"agent",
		"sandbox",
		"safe-functions",
		"cli"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/OrgSDK/plugins.git"
	},
	"homepage": "https://github.com/OrgSDK/plugins#readme",
	"bugs": {
		"url": "https://github.com/OrgSDK/plugins/issues"
	}
}
